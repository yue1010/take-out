<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.DishDetailMapper">

    <!-- 定义菜品详情结果映射 -->
    <resultMap id="DishDetailResultMap" type="com.itheima.vo.DishDetail">
        <result column="dish_detail_id" property="dishDetailId"/>
        <result column="dish_id" property="dishId"/>
        <result column="dish_name" property="dishName"/>
        <result column="dish_category" property="dishCategory"/>
        <result column="category_name" property="categoryName"/>
        <result column="unit_price" property="unitPrice"/>
        <result column="stock_qty" property="stockQty"/>
        <result column="mer_id" property="merId"/>
        <result column="mer_name" property="merName"/>
    </resultMap>

    <!-- 定义食材结果映射 -->
    <resultMap id="IngredientResultMap" type="com.itheima.pojo.Ingredient">
        <result column="ingr_name" property="ingrName"/>
        <result column="quantity" property="quantity"/>
    </resultMap>

    <!-- 根据菜品明细ID查询详情 -->
    <select id="selectDishDetailById" resultMap="DishDetailResultMap">
        SELECT
            dd.dish_detail_id,
            d.dish_id,
            d.dish_name,
            d.dish_category,
            dc.category_name,
            dd.unit_price,
            dd.stock_qty,
            dd.mer_id,
            m.mer_name
        FROM dish_detail dd
                 INNER JOIN dish d ON dd.dish_id = d.dish_id
                 INNER JOIN dish_categories dc ON d.dish_category = dc.dish_category
                 INNER JOIN merchant m ON dd.mer_id = m.mer_id
        WHERE dd.dish_detail_id = #{dishDetailId}
    </select>

    <!-- 根据菜品ID查询食材列表（假设存在dish_ingredient关联表） -->
    <select id="selectIngredientsByDishId" resultMap="IngredientResultMap">
        SELECT
            di.ingr_name,
            di.quantity
        FROM dish_ingredient di
        WHERE di.dish_id = #{dishId}
    </select>

</mapper>